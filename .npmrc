# Security hardening — added 2026-04-03
# Block lifecycle scripts (postinstall, preinstall, prepare) from all packages.
# This is the #1 npm supply chain attack vector.
ignore-scripts=true

# Require lock file to be present and up-to-date.
# Prevents silent version drift on install.
lockfile-version=3

# Disable funding and update-notifier noise
fund=false
update-notifier=false
